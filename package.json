{
  "name": "simply-stated-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -p simply-stated/tsconfig.json",
    "test": "run-s test:*",
    "test:runtime": "vitest run",
    "test:types": "tstyche",
    "typecheck": "tsc -p simply-stated/tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "simply-stated": "workspace:*",
    "tstyche": "^7.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
