{
  "name": "simply-stated",
  "version": "0.2.1",
  "description": "Strongly typed, declarative state machine modeling",
  "keywords": [
    "state-machine",
    "fsm",
    "state",
    "statechart",
    "typescript",
    "type-safe",
    "redux",
    "redux-toolkit"
  ],
  "license": "MIT",
  "author": "Szymon Masłowski",
  "homepage": "https://github.com/szymonmaslowski/simply-stated#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/szymonmaslowski/simply-stated.git",
    "directory": "simply-stated"
  },
  "bugs": {
    "url": "https://github.com/szymonmaslowski/simply-stated/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./redux-toolkit": {
      "types": "./dist/adapters/redux-toolkit/index.d.ts",
      "import": "./dist/adapters/redux-toolkit/index.js",
      "require": "./dist/adapters/redux-toolkit/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@reduxjs/toolkit": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@reduxjs/toolkit": {
      "optional": true
    }
  },
  "dependencies": {
    "type-fest": "^5.7.0"
  }
}
