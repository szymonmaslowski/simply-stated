{
  "name": "simply-stated",
  "version": "0.4.0",
  "description": "Strongly typed, declarative state machine modeling",
  "keywords": [
    "state-machine",
    "fsm",
    "state",
    "statechart",
    "typescript",
    "type-safe",
    "redux",
    "redux-toolkit"
  ],
  "license": "MIT",
  "author": "Szymon Masłowski",
  "homepage": "https://github.com/szymonmaslowski/simply-stated#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/szymonmaslowski/simply-stated.git",
    "directory": "simply-stated"
  },
  "bugs": {
    "url": "https://github.com/szymonmaslowski/simply-stated/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./redux-toolkit": {
      "types": {
        "import": "./dist/adapters/redux-toolkit/index.d.ts",
        "require": "./dist/adapters/redux-toolkit/index.d.cts"
      },
      "import": "./dist/adapters/redux-toolkit/index.js",
      "require": "./dist/adapters/redux-toolkit/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@reduxjs/toolkit": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@reduxjs/toolkit": {
      "optional": true
    }
  }
}
